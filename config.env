# ─────────────────────────────────────────────────────────
#  GasBook  |  config.env
#  DO NOT commit this file to version control!
# ─────────────────────────────────────────────────────────

# Flask
FLASK_ENV   = "production"
SECRET_KEY  = "gasbook-secret-key-change-in-prod-2024"

# MySQL Database
MYSQL_HOST      = "db"
MYSQL_USER      = "gasbook_user"
MYSQL_PASSWORD  = "gasbook_pass"
MYSQL_DATABASE  = "gasbook"
MYSQL_PORT      = "3306"    # internal Docker network port — always 3306 inside containers

# MySQL Root (used by Docker MySQL container init)
MYSQL_ROOT_PASSWORD = "rootpassword"

# App
FLASK_PORT = "5002"
DEBUG      = "False"

# Timezone (used for logging and date formatting)
TIMEZONE    = "Asia/Kolkata"

# CORS allowed origins (comma-separated)
CORS_ORIGINS = "http://localhost:5002,http://127.0.0.1:5002,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,null"

